# Kopiere diese Datei nach ".env" und trage deine Zugangsdaten ein.
# Die echte .env wird von Git ignoriert (.gitignore) und niemals hochgeladen.

HISINONE_USERNAME=dein-login
HISINONE_PASSWORD=dein-passwort

# Optional - Standardwerte gelten fuer die Hochschule Hannover.
# Fuer andere HISinOne-Hochschulen entsprechend anpassen.
HISINONE_BASE_URL=https://campusmanagement.hs-hannover.de
HISINONE_ICMS_URL=https://icms.hs-hannover.de/qisserver

# Studiengang-Knoten im Notenspiegel-Baum (URL-kodiert).
# Standard: abschl=84 (Bachelor), stgnr=1. Findest du in der URL des
# Notenspiegels als Parameter "nodeID", falls deiner abweicht.
HISINONE_NODE_ID=auswahlBaum%7Cabschluss%3Aabschl%3D84%2Cstgnr%3D1
